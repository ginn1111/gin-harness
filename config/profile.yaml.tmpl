# Deployment config for {{PROFILE}} (gin delivery pipeline)
# Template — machine-specific values replaced by setup.sh
# .env must export: GIN_API_KEY, GIN_BASE_URL

model:
  default: coder
  provider: custom
  base_url: {{GIN_BASE_URL}}
  api_key: ${GIN_API_KEY}

memory:
  memory_enabled: true
  user_profile_enabled: true
  memory_char_limit: 2200
  user_char_limit: 1375
  provider: byterover
  byterover:
    auto_extract: false

skills:
  external_dirs:
    - {{REPO_DIR}}/community/mattpocock-skills/skills
    - {{REPO_DIR}}/skills

_config_version: 33

custom_providers:
  - api_key: ${GIN_API_KEY}
    base_url: ${GIN_BASE_URL}
    default: coder
    name: {{GIN_HOST}}

platform_toolsets:
  cli:
    - code_execution
    - delegation
    - file
    - kanban
    - memory
    - session_search
    - skills
    - terminal
    - todo
    - vision
    - web

known_plugin_toolsets:
  cli:
    - spotify

display:
  skin: {{DISPLAY_SKIN}}
